{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm --filter @sondor/ui build && pnpm --filter @sondor/web build",
  "devCommand": "pnpm --filter @sondor/web dev",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": "nextjs",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- apps/web packages/ui pnpm-lock.yaml package.json"
}
