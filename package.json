{
  "name": "sondor-ui-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Sondor UI — AI Chatbot UI Kit (monorepo root)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bilguunint/sondor-ai-chatbot.git"
  },
  "scripts": {
    "dev": "pnpm --filter @sondor/web dev",
    "build": "pnpm --filter sondor-ui build && pnpm --filter @sondor/web build",
    "build:ui": "pnpm --filter sondor-ui build",
    "build:web": "pnpm --filter @sondor/web build",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r exec rimraf dist .next .turbo node_modules",
    "start": "pnpm --filter @sondor/web start"
  },
  "engines": {
    "node": ">=18.18.0",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.4"
}
